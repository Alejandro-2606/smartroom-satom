# Copia este archivo como ".env" y rellena tus datos reales.
# NUNCA subas el archivo ".env" real a GitHub.

# Connection string que te da NeonTech (la encuentras en tu dashboard
# de Neon, en "Connection Details" -> "Connection string")
DATABASE_URL=postgresql://usuario:password@ep-xxxxx.us-east-2.aws.neon.tech/smartroom?sslmode=require

# Clave secreta de Flask para firmar las sesiones (invéntate cualquier texto largo)
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria

# Clave que usará el ESP32 para autenticarse al enviar datos
DEVICE_API_KEY=clave-secreta-para-el-esp32
